# GCP connection settings
GCP_PROJECT_ID=your-project-id
GCP_LOCATION=us
DOCUMENTAI_PROCESSOR_ID=your-processor-id
GOOGLE_APPLICATION_CREDENTIALS=./your-service-account-key.json

# Batch processing settings
GCS_BUCKET=your-gcs-bucket-name
MAX_ONLINE_PAGES=15
ONLINE_TIMEOUT=600
BATCH_TIMEOUT=3600

# Layout Parser processing options (all defaults: highest quality)
RETURN_IMAGES=true
RETURN_BOUNDING_BOXES=true
CHUNK_SIZE=1024
INCLUDE_ANCESTOR_HEADINGS=true

# OCR settings (Layout Parser has built-in OCR - keep false)
# Change to true when using an OCR processor
ENABLE_OCR_CONFIG=false
ENABLE_NATIVE_PDF_PARSING=true
ENABLE_SYMBOL=true
ENABLE_IMAGE_QUALITY_SCORES=true
COMPUTE_STYLE_INFO=true

# Premium features (only available on OCR 2.0+ processors)
ENABLE_SELECTION_MARK_DETECTION=false
ENABLE_MATH_OCR=false
